generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  FACULTY
  STUDENT
}

enum FacultyRole {
  PRIMARY
  SECONDARY
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String?
  supabaseId String?  @unique
  role       Role     @default(ADMIN)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student    Student?
  faculty    Faculty?
}

model Student {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique

  panelId     Int?
  panel       Panel?       @relation(fields: [panelId], references: [id])

  userId      Int?         @unique
  user        User?        @relation(fields: [userId], references: [id])

  attendance  Attendance[]
  evaluations Evaluation[]

  createdAt   DateTime @default(now())
}

model Faculty {
  id           Int      @id @default(autoincrement())
  name         String

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  userId       Int?     @unique
  user         User?    @relation(fields: [userId], references: [id])

  panelLinks   PanelFaculty[]

  markedAttendance Attendance[]
  evaluations      Evaluation[]

  createdAt DateTime @default(now())
}

// ------------------ HIERARCHY ------------------

model Division {
  id        Int      @id @default(autoincrement())
  name      String   @unique

  schools   School[]

  createdAt DateTime @default(now())
}

model School {
  id          Int      @id @default(autoincrement())
  name        String

  divisionId  Int
  division    Division @relation(fields: [divisionId], references: [id])

  departments Department[]

  createdAt   DateTime @default(now())

  @@unique([name, divisionId]) // 🔥 FIXED
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String

  schoolId  Int
  school    School   @relation(fields: [schoolId], references: [id])

  panels    Panel[]
  faculty   Faculty[]

  createdAt DateTime @default(now())

  @@unique([name, schoolId])
}

model Panel {
  id           Int      @id @default(autoincrement())
  name         String

  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])

  students     Student[]

  facultyLinks PanelFaculty[]

  createdAt    DateTime @default(now())

  @@unique([name, departmentId])
}

// 🔥 MANY-TO-MANY (FACULTY ↔ PANEL with ROLE) */
model PanelFaculty {
  id        Int         @id @default(autoincrement())

  panelId   Int
  facultyId Int

  role      FacultyRole

  panel     Panel   @relation(fields: [panelId], references: [id])
  faculty   Faculty @relation(fields: [facultyId], references: [id])

  @@unique([panelId, facultyId])
}
// ------------------ CORE ------------------ */

model Attendance {
  id        Int      @id @default(autoincrement())

  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])

  facultyId Int?
  faculty   Faculty? @relation(fields: [facultyId], references: [id])

  date      DateTime @default(now())
  status    String   // PRESENT / ABSENT
}

model Evaluation {
  id        Int      @id @default(autoincrement())

  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])

  facultyId Int
  faculty   Faculty  @relation(fields: [facultyId], references: [id])

  marks     Float
  remarks   String?

  createdAt DateTime @default(now())
}